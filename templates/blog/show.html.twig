{% extends 'base.html.twig' %}

{% block body %}

<section class="row article">
    <article class="col-md-3 mw-auto text-center border border-dark mb-3 p-3 mt-3 mr-1">
        <h2>{{ article.title }}</h2>
        <div class="metadata">Ecrit le {{ article.createdAt | date('d/m/Y') }} à {{ article.createdAt | date('H:i:s') }} dans la catégorie Politique</div>
        <div class="content">
            <img src="{{ article.image }}" alt="image de l'article"><hr>
            {{ article.content | raw }}
        </div>
    </article>
</section>


{% endblock %}