<div class="container my-5 text-center">
    <h2>Commentaires</h2>
        <div class="row">
            {% for comment in article.comments %}
            <div class="col-md-6">
                <div class="container my-4 border">
                    <div class="py-4">
                        {{ comment.author }} (<small>{{ comment.createdAt | date('d/m/Y à h:i:s')}}</small>)
                    </div>
                    <hr>
                    <div>
                        {{ comment.content | raw }}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
</div>

